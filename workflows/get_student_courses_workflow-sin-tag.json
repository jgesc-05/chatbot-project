  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nSELECT \n  e.id_estudiante,\n  e.nombre_completo,\n  e.programa_academico,\n  e.semestre_actual,\n  cm.nombre_materia,\n  cm.pilar,\n  ce.semestre AS periodo_tomado,\n  ce.anio AS anio_tomado,\n  rn.nota\nFROM estudiante e\nLEFT JOIN cursos_estudiantes ce ON ce.id_estudiante = e.id_estudiante\nLEFT JOIN catalogo_materias_ccd cm ON cm.codigo_materia = ce.codigo_materia\nLEFT JOIN registro_nota rn ON rn.id_estudiante = ce.id_estudiante \n                            AND rn.codigo_materia = ce.codigo_materia\nWHERE e.id_estudiante = '{{ $json.student_id }}'\nORDER BY cm.pilar, ce.anio, ce.semestre;",
        "options": {}
      },
